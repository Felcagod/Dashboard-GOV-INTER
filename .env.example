# Copie este arquivo para .env.local e preencha os valores

# Google OAuth Client ID
# Obtenha em: https://console.cloud.google.com/
REACT_APP_GOOGLE_CLIENT_ID=seu_google_client_id_aqui

# URL do Backend (opcional)
# Padrão: http://localhost:5000
REACT_APP_API_URL=http://localhost:5000

# ==================== JIRA CONFIG (Backend Proxy) ====================
# Se usar backend proxy para JIRA (recomendado)

# JIRA Domain
JIRA_DOMAIN=c4br.atlassian.net

# JIRA Email
JIRA_EMAIL=wagner_cardoso_2@carrefour.com

# JIRA API Token
# Obtenha em: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=seu_jira_token_aqui

# Token JIRA de fallback
# Opcional: usado se o token principal falhar ou não responder
JIRA_TOKEN_FALLBACK=seu_jira_token_de_fallback_aqui

# Ou, para múltiplos tokens em uma única variável:
# JIRA_TOKENS=token_principal,token_fallback

# Porta do backend proxy (use BACKEND_PORT para o proxy Node)
BACKEND_PORT=5001

